@prefix agents: <https://w3id.org/zeri/ontology/zamo/agents#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix zamo_ext: <https://w3id.org/zeri/ontology/zamo/extended#> .

zamo_ext:isUncleOrAuntOf a owl:ObjectProperty ;
    rdfs:domain agents:Person ;
    rdfs:range agents:Person ;
    rdfs:subPropertyOf schema:relatedTo .

