<https://w3id.org/zeri/data/event/E_2> a crmsci:S19_Encounter_Event ;
    rdfs:label "Scoperta del tesoro di Boscoreale"@it ;
    crm:P14_carried_out_by <https://w3id.org/zeri/data/org/CA_I>,
