<https://w3id.org/zeri/data/event/E_14_0> a crm:E8_Acquisition,
        events:Gift ;
    rdfs:label "Donazione della collezione di Stefano Bardini"@it ;
    rdfs:comment "L'antiquario Stefano Bardini, morto nel 1922, donò la sua collezione e il palazzo di sua proprietà al comune di Firenze, che decise tre anni dopo di aprire un museo a lui dedicato."@it ;
    events:hasDate "1924"^^xsd:gYear ;
    events:hasSurrender <https://w3id.org/zeri/data/org/BA_II>,
        <https://w3id.org/zeri/data/person/BA_II_1> ;
    events:transfersPropertyOf <https://w3id.org/zeri/data/lot/E_14_0> .

