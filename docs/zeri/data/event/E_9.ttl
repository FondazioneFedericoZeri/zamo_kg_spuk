<https://w3id.org/zeri/data/event/E_9> a crm:E96_Purchase,
        events:Purchase ;
    rdfs:label "Vendita all'asta - collezione G. Ferroni"@it ;
    rdfs:comment "Nel 1909, presso la casa d'aste \"Jandolo&Tavazzi\" di Roma,  in collaborazione con la \"Galleria Sangiorgi\",  venne venduta parte della collezione di Giovacchino Ferroni. La vendita è stata ampiamente reclamizzate e descritta anche sulle pagine de “L’Antiquario”."@it ;
    events:hasDate "1909"^^xsd:gYear ;
    events:hasFacilitator <https://w3id.org/zeri/data/org/JA-TA>,
        <https://w3id.org/zeri/data/org/SA_IV>,
        <https://w3id.org/zeri/data/person/SA_IV_1> ;
    events:hasSurrender <https://w3id.org/zeri/data/person/FE_1> ;
    events:transfersPropertyOf <https://w3id.org/zeri/data/lot/E_9> .

